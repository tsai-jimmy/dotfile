#!/usr/bin/env bash
#
# pre-commit hook: 在提交前掃描暫存內容，阻擋金鑰 / 憑證外洩。
# 優先使用 gitleaks；若未安裝則退回內建 regex 後援掃描。
#
# 安裝 gitleaks（建議）：
#   brew install gitleaks
#
# 緊急略過（請務必確認無誤）：
#   git commit --no-verify

set -euo pipefail

RED='\033[0;31m'; YELLOW='\033[0;33m'; GREEN='\033[0;32m'; NONE='\033[0m'
REPO_ROOT="$(git rev-parse --show-toplevel)"

# --- 1. 優先使用 gitleaks ---
if command -v gitleaks >/dev/null 2>&1; then
  if gitleaks protect --staged --redact \
       $( [ -f "$REPO_ROOT/.gitleaks.toml" ] && echo "--config=$REPO_ROOT/.gitleaks.toml" ); then
    exit 0
  else
    echo -e "${RED}✗ gitleaks 偵測到疑似機密內容，已阻擋提交。${NONE}"
    echo -e "${YELLOW}  確認為誤判時，可調整 .gitleaks.toml allowlist，或以 --no-verify 略過。${NONE}"
    exit 1
  fi
fi

# --- 2. 後援：內建 regex 掃描（gitleaks 未安裝時）---
echo -e "${YELLOW}⚠ 未偵測到 gitleaks，改用內建後援掃描（建議 brew install gitleaks）。${NONE}"

PATTERNS=(
  'AKIA[0-9A-Z]{16}'                         # AWS Access Key ID
  'aws_secret_access_key'                     # AWS secret
  'ghp_[A-Za-z0-9]{36}'                      # GitHub PAT (classic)
  'github_pat_[A-Za-z0-9_]{22,}'             # GitHub PAT (fine-grained)
  'gho_[A-Za-z0-9]{36}'                      # GitHub OAuth
  'sk-[A-Za-z0-9]{20,}'                      # OpenAI / 通用 sk-
  'xox[baprs]-[A-Za-z0-9-]{10,}'             # Slack token
  'AIza[0-9A-Za-z_-]{35}'                    # Google API key
  '-----BEGIN [A-Z ]*PRIVATE KEY-----'       # PEM 私鑰
  'eyJ[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,}\.' # JWT
)

FOUND=0
# 排除安全工具自身檔案（其內含特徵字串會造成誤判）
SELF_FILES='^(hooks/pre-commit|\.gitleaks\.toml)$'
SCAN_FILES="$(git diff --cached --name-only --diff-filter=ACM | grep -vE "$SELF_FILES" || true)"

for f in $SCAN_FILES; do
  # 僅取新增行（去掉 +++ 標頭）
  ADDED="$(git diff --cached --no-color -U0 -- "$f" | grep -E '^\+' | grep -vE '^\+\+\+')"
  [ -z "$ADDED" ] && continue
  for pat in "${PATTERNS[@]}"; do
    if echo "$ADDED" | grep -E "$pat" >/dev/null 2>&1; then
      echo -e "${RED}✗ ${f} 命中疑似機密特徵：${NONE} ${pat}"
      FOUND=1
    fi
  done
done

if [ "$FOUND" -ne 0 ]; then
  echo -e "${RED}提交已阻擋。請移除機密後再試，或以 git commit --no-verify 略過（風險自負）。${NONE}"
  exit 1
fi

echo -e "${GREEN}✓ 後援掃描通過，未發現明顯機密特徵。${NONE}"
exit 0
